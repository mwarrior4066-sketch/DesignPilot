  "domain_shortlists": {
    "UI-safe": [
      "Inter",
      "Geist Sans",
      "Public Sans",
      "IBM Plex Sans",
      "Roboto Flex",
      "SF Pro when native Apple is allowed"
    ],
    "Dashboard-safe": [
      "Inter",
      "Geist Sans",
      "IBM Plex Sans",
      "Public Sans",
      "Roboto Flex",
      "JetBrains Mono / IBM Plex Mono / Geist Mono"
    ],
    "Public-sector": [
      "Public Sans",
      "Noto Sans",
      "IBM Plex Sans",
      "Source Sans 3",
      "Sarabun"
    ],
    "Editorial-safe": [
      "Charter",
      "Source Serif 4",
      "Tiempos Text",
      "Literata",
      "Merriweather",
      "Georgia"
    ],
    "Branding-safe": [
      "Söhne",
      "Akkurat",
      "Graphik",
      "Avenir Next",
      "GT Sectra",
      "Editorial New",
      "Canela"
    ],
    "Accessibility-safe": [
      "Atkinson Hyperlegible Next",
      "Atkinson Hyperlegible Mono",
      "Lexend",
      "Luciole",
      "Andika"
    ],
    "Multilingual-safe": [
      "Noto Sans",
      "Noto Serif",
      "Noto Sans CJK / Source Han Sans",
      "IBM Plex Sans",
      "Noto Sans Arabic / IBM Plex Sans Arabic / Cairo"
    ]
  },
  "feature_filters": {
    "strong_small_size_ui_behavior": [
      "Inter",
      "Geist Sans",
      "IBM Plex Sans",
      "Public Sans",
      "Open Sans",
      "Roboto Flex"
    ],
    "tabular_figures_and_dense_data": [
      "Inter",
      "IBM Plex Sans",
      "Geist Sans",
      "Roboto Flex",
      "IBM Plex Mono",
      "JetBrains Mono"
    ],
    "variable_first": [
      "Roboto Flex",
      "Inter",
      "Mona Sans",
      "Atkinson Hyperlegible Next",
      "Atkinson Hyperlegible Mono",
      "Recursive",
      "Cabinet Grotesk"
    ],
    "developer_products": [
      "Geist Sans + Geist Mono",
      "IBM Plex Sans + Plex Mono",
      "Inter + JetBrains Mono",
      "Mona Sans + Hubot Sans"
    ],
    "multiscript_systems": [
      "Noto families",
      "Source Han families",
      "IBM Plex Sans",
      "Brill"
    ]
  },
  "family_profiles": {
    "Inter": {
      "best_for": [
        "product UI",
        "dashboards",
        "documentation"
      ],
      "strengths": [
        "screen-first design",
        "open counters",
        "broad ecosystem"
      ],
      "caution": "still specify fallback stacks and numeric feature needs"
    },
    "Geist Sans": {
      "best_for": [
        "developer-facing products",
        "modern app UI"
      ],
      "strengths": [
        "mono companion",
        "easy npm path",
        "developer tone"
      ],
      "caution": "Google Fonts path is partial compared with npm or zip"
    },
    "IBM Plex Sans": {
      "best_for": [
        "enterprise systems",
        "global products",
        "documentation"
      ],
      "strengths": [
        "coherent family",
        "large language support",
        "strong mono companion"
      ],
      "caution": "technical tone is stronger than neutral-luxury"
    },
    "Public Sans": {
      "best_for": [
        "public sector",
        "civic tools",
        "accessible neutral UI"
      ],
      "strengths": [
        "high clarity",
        "institutional trust",
        "open-source"
      ],
      "caution": "less distinctive for expressive branding"
    },
    "Atkinson Hyperlegible Next": {
      "best_for": [
        "accessibility-sensitive interfaces",
        "inclusive dashboards"
      ],
      "strengths": [
        "strong letter distinction",
        "expanded 2025 family",
        "variable support"
      ],
      "caution": "not a default branding face for every project"
    },
    "Noto Sans": {
      "best_for": [
        "multilingual systems",
        "global fallback strategy"
      ],
      "strengths": [
        "script coverage",
        "open licensing",
        "harmonized global system"
      ],
      "caution": "ship only the scripts you need"
    }
  },
  "substitutions": [
    {
      "Premium / commercial": "Helvetica / SF Pro",
      "High-quality open-source substitute": "Inter / Public Sans / Roboto Flex",
      "Why it works": "neo-grotesque neutrality and broad UI fit"
    },
    {
      "Premium / commercial": "Graphik / Suisse / Neue Montreal",
      "High-quality open-source substitute": "Inter / Figtree / Archivo",
      "Why it works": "neutral modern product behavior"
    },
    {
      "Premium / commercial": "Proxima Nova / Gotham",
      "High-quality open-source substitute": "Montserrat / Work Sans / Figtree",
      "Why it works": "geometric construction and public availability"
    },
    {
      "Premium / commercial": "Avenir / Frutiger",
      "High-quality open-source substitute": "Lato / Open Sans / Nunito Sans",
      "Why it works": "humanist softness and readability"
    },
    {
      "Premium / commercial": "Freight Text / Miller Text",
      "High-quality open-source substitute": "Source Serif 4 / Literata / Merriweather",
      "Why it works": "editorial readability and strong text color"
    },
    {
      "Premium / commercial": "Didot / Bodoni",
      "High-quality open-source substitute": "Bodoni Moda / Playfair Display",
      "Why it works": "high-contrast editorial feel with easier access"
    },
    {
      "Premium / commercial": "Whyte / Söhne Mono",
      "High-quality open-source substitute": "IBM Plex Mono / JetBrains Mono / Geist Mono",
      "Why it works": "technical clarity and implementation support"
    }
  ],
  "native_fallbacks": [
    {
      "platform": "Apple stack",
      "stack": "-apple-system, BlinkMacSystemFont, \"SF Pro Text\", \"Helvetica Neue\", Arial, sans-serif"
    },
    {
      "platform": "Windows stack",
      "stack": "\"Segoe UI\", Tahoma, Arial, sans-serif"
    },
    {
      "platform": "Android / cross-platform fallback",
      "stack": "Roboto, \"Noto Sans\", Arial, sans-serif"
    },
    {
      "platform": "Monospace fallback",
      "stack": "\"JetBrains Mono\", \"IBM Plex Mono\", \"SFMono-Regular\", Menlo, Consolas, monospace"
    },
    {
      "platform": "Global sans fallback",
      "stack": "\"Noto Sans\", \"Inter\", Arial, sans-serif"
    }
  ],
  "default_metrics": {
    "body_size_start": "16px minimum",
    "body_leading": "~1.5x",
    "display_leading": "~1.1x to 1.25x",
    "line_length": "45-75 CPL, ~66 CPL default",
    "optical_sizing": "use when supported"
  }
}
