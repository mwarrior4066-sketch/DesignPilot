{
  "version": "1.1.0",
  "purpose": "Compact low-token font selection index for role buckets, domain shortlists, feature filters, substitutions, and fallback logic.",
  "source": "src/libraries/FONT_LIBRARY.md",
  "selection_sequence": [
    "role",
    "script_region",
    "delivery_constraint",
    "structure",
    "feature_need",
    "primary_family",
    "fallback_path",
    "licensing_risk"
  ],
